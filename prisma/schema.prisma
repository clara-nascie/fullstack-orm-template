generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  //coluna de identificação única 
  //o id representa cada usuário 
  // a string define que ele é um texto
  //id @id -> chave primária
  // @default(uuid()) -> gera um id automático no formato uuid
  
  id String @id @default(uuid())
  name String
  email String @unique

//um usuario pode ter varias perguntas 
  questions Question[]

//como eu quero que a tabela seja chamada dentro do banco de dados 
  @@map("users")
}

model Question {
  id String @id @default(uuid())
  title String
  content String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")

//define que a coluna user_id é uma chave estrangeira que referencia a tabela users na coluna id
//preciso falar la em user que um usuario pode ter varias perguntas 
  user User @relation(fields: [userId], references: [id])

  //relacionamento 
  @@map("questions")
}